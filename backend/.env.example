# LegalPulse backend env vars. Copy to backend/.env and fill in the values
# you need — most are optional. The app boots without any of these (the
# demo UI works on heuristic engines + pre-baked snapshot).

# --- Server / deployment ---
# PORT is auto-injected by Render. For local dev override only if 8000 is in use.
# PORT=8000
NODE_ENV=development

# Secret used to encrypt per-user anthropicApiKey at rest with AES-256-GCM.
# Either a 64-char hex string (preferred, gives 32 random bytes) or any
# passphrase (hashed to 32 bytes). REQUIRED for production — without it
# API keys are stored in plaintext. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# LEGALPULSE_SECRET_KEY=

# Where the sql.js database file lives. Defaults:
#   - production: backend/storage/legalpulse.db
#   - dev: %LOCALAPPDATA%/LegalPulse/legalpulse.db on Windows, ~/Library/.../legalpulse.db elsewhere
# LEGALPULSE_DB_PATH=

# CORS — explicit comma-separated origins allowed in addition to localhost +
# RENDER_EXTERNAL_URL + *.onrender.com. Tighten this in production.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com

# --- LLM access (Anthropic) ---
# Option A — direct Anthropic API key (per-user BYOK is the preferred path
# inside the app; this is for server-side ambient access).
# ANTHROPIC_API_KEY=sk-ant-...

# Option B — gateway (Databricks / Anthropic proxy). When both BASE_URL and
# AUTH_TOKEN are set, the server treats LLM access as "ambient" and lets
# anonymous demo users invoke LLM-backed routes without their own BYOK key.
# ANTHROPIC_BASE_URL=https://your-gateway.example.com/v1
# ANTHROPIC_AUTH_TOKEN=...
# ANTHROPIC_CUSTOM_HEADERS={"x-databricks-workspace-id":"123"}

# Pin specific model IDs the agents request. Leave unset to use library defaults.
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-7
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5

# --- External signal sources ---
# SEC EDGAR requires a User-Agent identifying you per their fair-use policy.
SEC_EDGAR_USER_AGENT=LegalPulse contact@example.com

# Optional API keys for paid / metered sources. Without these the orchestrator
# silently skips the source.
# TAVILY_API_KEY=
# COMPANIES_HOUSE_API_KEY=
# COURTLISTENER_TOKEN=
